# Copy to .env and adjust. Backend reads these when started from repo root or backend/.

# API
API_HOST=0.0.0.0
API_PORT=8000

# MySQL (matches docker-compose service `mysql`, host port 3307 to avoid local 3306 conflicts)
DATABASE_URL=mysql+pymysql://ppt_user:ppt_password@127.0.0.1:3307/ppt_outline

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# LLM (OpenAI-compatible client)
USE_REAL_LLM=false
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=120
OPENAI_API_KEY=
# e.g. https://api.deepseek.com — must match your provider.
OPENAI_BASE_URL=

# Retrieval (paths relative to cwd when starting uvicorn, usually backend/)
RETRIEVAL_DOCUMENTS_DIR=sample_docs
RETRIEVAL_CHROMA_DIR=./chroma_data

# Generation pipeline
GENERATION_WORKER_MAX_WORKERS=2
GENERATION_MAX_RETRIES=2
# Allow long runs when HF models download or CPU embed/rerank is slow; tighten in production after cache warm.
GENERATION_HARD_TIMEOUT_SECONDS=3600
# Should exceed GENERATION_HARD_TIMEOUT_SECONDS so crash-recovery does not treat running jobs as stale.
RECOVERY_STALE_GENERATING_SECONDS=4200
# Background-load embedding + reranker at startup (recommended). Set false to defer until first request.
RETRIEVAL_WARMUP_ON_STARTUP=true

# Optional (Windows): silence Hugging Face hub symlink cache warning
# HF_HUB_DISABLE_SYMLINKS_WARNING=1
