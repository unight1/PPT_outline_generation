# Copy to .env and adjust. Backend reads these when started from repo root or backend/.

# API
API_HOST=0.0.0.0
API_PORT=8000

# MySQL (matches docker-compose service `mysql`, host port 3307 to avoid local 3306 conflicts)
DATABASE_URL=mysql+pymysql://ppt_user:ppt_password@127.0.0.1:3307/ppt_outline

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# LLM (add when you integrate LangChain / LangGraph)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
